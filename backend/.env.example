# ============================================================================
# Clarity Backend Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in your actual API keys
# ============================================================================

# ---------------------------------------------------------------------------
# Google Gemini API Key
# ---------------------------------------------------------------------------
# Where to get it: https://aistudio.google.com/app/apikey
# 1. Go to Google AI Studio
# 2. Click "Get API Key"
# 3. Create a new API key or use an existing one
# 4. Copy the key and paste it below
GOOGLE_API_KEY=AIzaSyC74JnDHFGBpIkHb34Q7xgPtWqYb_S75SQ

# ---------------------------------------------------------------------------
# ElevenLabs API Key & Voice ID
# ---------------------------------------------------------------------------
# Where to get it: https://elevenlabs.io/app/settings/api-keys
# 1. Sign up or log in to ElevenLabs
# 2. Go to Settings > API Keys
# 3. Create a new API key
# 4. Copy the key and paste it below
ELEVENLABS_API_KEY=sk_c864dfb3132250321514fdf52aade02ef7d1f0b4ab214aba

# Voice ID:
# 1. Go to https://elevenlabs.io/app/voice-library
# 2. Choose a voice or create your own
# 3. Click on the voice to see its Voice ID
# 4. Copy the Voice ID and paste it below
ELEVENLABS_VOICE_ID=xkZbQNAECGEIWAfDyzJy

# ---------------------------------------------------------------------------
# FAL.AI API Key (for MuseTalk video processing)
# ---------------------------------------------------------------------------
# Where to get it: https://fal.ai/dashboard/keys
# 1. Sign up or log in to fal.ai
# 2. Go to Dashboard > API Keys
# 3. Create a new API key
# 4. Copy the key and paste it below
# Note: MuseTalk costs ~$0.05 per second of video processed
FAL_API_KEY=efc7f336-6394-400c-9a06-de12b49d05e7:77686b495fd0823ec12bf9d934594b32

# ---------------------------------------------------------------------------
# Pipeline Configuration
# ---------------------------------------------------------------------------
# Options: "native_multimodal" or "scribe_first"
# - native_multimodal: Gemini processes audio directly (Path 1)
# - scribe_first: ElevenLabs STT → Gemini text → TTS (Path 2)
PIPELINE_MODE=scribe_first

# ---------------------------------------------------------------------------
# Preservation-First Video Processing Policy (Optional)
# ---------------------------------------------------------------------------
# When true, only edit when transcript change is clearly significant.
CLARITY_STRICT_PRESERVE_MODE=true

# Minimum normalized change ratio before invoking MuseTalk on a segment.
CLARITY_MIN_EDIT_RATIO=0.08

# Changed span shaping (seconds)
CLARITY_EDIT_SPAN_PADDING_S=0.12
CLARITY_EDIT_MIN_SPAN_S=0.35
CLARITY_EDIT_MERGE_GAP_S=0.18
CLARITY_EDIT_MAX_SPAN_S=1.5

# Audio pacing alignment constraints for healed snippets
CLARITY_AUDIO_MIN_STRETCH_RATIO=0.8
CLARITY_AUDIO_MAX_STRETCH_RATIO=1.25
CLARITY_AUDIO_ALIGNMENT_TOLERANCE_S=0.12

# Dark-scene safeguard: prefer preserving original video unless edit is critical
CLARITY_DARK_SCENE_LUMA_THRESHOLD=45.0
CLARITY_DARK_SCENE_EDIT_RATIO_CRITICAL=0.35

# ---------------------------------------------------------------------------
# Debug Settings (Optional)
# ---------------------------------------------------------------------------
# Set to "true" to enable verbose debug logging
CLARITY_DEBUG_ENABLED=false

# Directory for debug outputs (leave empty to disable file logging)
CLARITY_DEBUG_DIR=
